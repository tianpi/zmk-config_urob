#define __VARIOUS

////////////////////////////////

// tap: space | shift + tap: dot -> space -> sticky shift | hold: activate layer
ZMK_HOLD_TAP(ht__mo__mm_space_dotspaceshift,
    flavor = "balanced";
    tapping-term-ms = <200>;
    quick-tap-ms = <QUICK_TAP_MS>;
    bindings = <&mo>, <&mm_space_dotspaceshift>;
)
ZMK_MOD_MORPH_SIMPLE(mm_space_dotspaceshift, SFT, &kp SPACE, &macro_dotspaceshift)

ZMK_MACRO(macro_dotspaceshift,
    wait-ms = <0>;
    tap-ms = <5>;
    bindings = <&kp DOT &kp SPACE &sk LSHFT>;
)

////////////////////////////////

// tap: copy | double-tap: cut
ZMK_TAP_DANCE(td_copy_cut,
    tapping-term-ms = <200>;
    bindings = <&kp APPLY_MODS(MOD_LCTL, INS)>, <&kp APPLY_MODS(MOD_LCTL, X)>;
)

////////////////////////////////////////////////////////////////

#define __KEYMAPS

//
// ╭─────┬─────┬─────┬─────┬─────╮           ╭─────┬─────┬─────┬─────┬─────╮
// │ LC5 │ LC4 │ LC3 │ LC2 │ LC1 │           │ LC5 │ LC3 │ LC5 │ LC5 │ LC5 │
// ├─────┼─────┼─────┼─────┼─────┼─────┬─────┼─────┼─────┼─────┼─────┼─────┤
// │ LN5 │ LN4 │ LN3 │ LN2 │ LN1 │ LN0 │ RN0 │ RN1 │ RN2 │ RN3 │ RN4 │ RN5 │
// ├─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┤
// │ LT5 │ LT4 │ LT3 │ LT2 │ LT1 │ LT0 │ RT0 │ RT1 │ RT2 │ RT3 │ RT4 │ RT5 │
// ├─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┤
// │ LM5 │ LM4 │ LM3 │ LM2 │ LM1 │ LM0 │ RM0 │ RM1 │ RM2 │ RM3 │ RM4 │ RM5 │
// ├─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┤
// │ LB5 │ LB4 │ LB3 │ LB2 │ LB1 │ LB0 │ RB0 │ RB1 │ RB2 │ RB3 │ RB4 │ RB5 │
// ├─────┼─────┼─────┼─────┼─────┼─────┴─────┼─────┼─────┼─────┼─────┼─────┤
// │ LF5 │ LF4 │ LF3 │ LF2 │ LF1 │           │ RF1 │ RF2 │ RF3 │ RF4 │ RF5 │
// ├─────┼─────┼─────┼─────┴─────╯           ╰─────┴─────┼─────┼─────┼─────┤
// │ LH5 │ LH4 │ LH3 │                                   │ RH3 │ RH4 │ RH5 │
// ├─────┼─────┼─────┤                                   ├─────┼─────┼─────┤
// │ LH2 │ LH1 │ LH0 │                                   │ RH0 │ RH1 │ RH2 │
// ╰─────┴─────┴─────╯                                   ╰─────┴─────┴─────╯
//
//       ╭─────┬─────┬─────┬─────┬─────┬─────┬─────┬─────┬─────┬─────╮
//       │ LT4 │ LT3 │ LT2 │ LT1 │ LT0 │ RT0 │ RT1 │ RT2 │ RT3 │ RT4 │
//       ├─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┤
//       │ LM4 │ LM3 │ LM2 │ LM1 │ LM0 │ RM0 │ RM1 │ RM2 │ RM3 │ RM4 │
//       ├─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┤
//       │ LB4 │ LB3 │ LB2 │ LB1 │ LB0 │ RB0 │ RB1 │ RB2 │ RB3 │ RB4 │
//       ├─────┼─────┼─────┴─────┴─────┴─────┴─────┴─────┼─────┼─────┤
//       │ LH1 │ LH0 │                                   │ RH0 │ RH1 │
//       ╰─────┴─────╯                                   ╰─────┴─────╯


////////////////////////////////////////////////////////////////

#define ____KEYMAP_BASE

////////////////////////////////
// tap: sticky-shift | shift + tap/ double-tap: caps-word | hold: shift

ZMK_MOD_MORPH(mm_capsword_capslock,
    bindings = <&caps_word>, <&kp CAPSLOCK>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
)

&caps_word {  // mods deactivate caps-word, requires PR #1451
    /delete-property/ ignore-modifiers;
};

////////////////////////////////
// tap: num-word | double-tap: sticky num-layer | hold: num-layer

// #define SMART_NUM &smartnum__ht_mo_td NUM 0

// ZMK_HOLD_TAP(smartnum__ht_mo_td,
//     flavor = "balanced";
//     tapping-term-ms = <200>;
//     quick-tap-ms = <QUICK_TAP_MS>;
//     bindings = <&mo>, <&smartnum__td_numword_sl>;
// )

// ZMK_TAP_DANCE(smartnum__td_numword_sl,
//     tapping-term-ms = <200>;
//     bindings = <&num_word NUM>, <&sl NUM>;  // reverse this for sticky-num on single tap
// )

ZMK_MOD_MORPH(mm_numword_numlock,
    bindings = <&num_word NUM>, <&tog NUM>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
)

&num_word {
    continue-list = <
        BSPC DEL
        DOT PLUS MINUS ASTERISK SLASH
        KP_DOT KP_PLUS KP_MINUS KP_ASTERISK KP_SLASH
    >;
};

////////////////////////////////

ZMK_MACRO(macro_cancel,
    wait-ms = <0>;
    tap-ms = <5>;
    bindings = <&kp K_CANCEL>, <&to BASE>;
)

ZMK_HOLD_TAP(ht__macro_cancel__kp,
    flavor = "balanced";
    tapping-term-ms = <200>;
    quick-tap-ms = <QUICK_TAP_MS>;
    bindings = <&macro_cancel>, <&kp>;
)

////////////////////////////////

ZMK_HOLD_TAP_RHRM_KP_MM(mm_dot_colon)
ZMK_HOLD_TAP_RHRM_KP_MM(mm_dot_doublequotes)
ZMK_HOLD_TAP_RHRM_KP_MM(mm_excl_qmark)

////////////////

GLV80_LAYER(base,
// ╭─────┬─────┬─────┬─────┬─────╮           ╭─────┬─────┬─────┬─────┬─────╮
// │ LC5 │ LC4 │ LC3 │ LC2 │ LC1 │           │ LC5 │ LC3 │ LC5 │ LC5 │ LC5 │
    &kp F1
    &kp F2
    &kp F3
    &kp F4
    &kp F5

    &kp F6
    &kp F7
    &kp F8
    &kp F9
    &kp F10
// ├─────┼─────┼─────┼─────┼─────┼─────┬─────┼─────┼─────┼─────┼─────┼─────┤
// │ LN5 │ LN4 │ LN3 │ LN2 │ LN1 │ LN0 │ RN0 │ RN1 │ RN2 │ RN3 │ RN4 │ RN5 │
    &kp EQUAL

    &kp N1
    &kp N2
    &kp N3
    &kp N4
    &kp N5

    &kp N6
    &kp N7
    &kp N8
    &kp N9
    &kp N0

    &kp MINUS /* DASH | LOW DASH */
// ├─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┤
// │ LT5 │ LT4 │ LT3 │ LT2 │ LT1 │ LT0 │ RT0 │ RT1 │ RT2 │ RT3 │ RT4 │ RT5 │
    &mm_capsword_capslock

    &kp Q
    &LHRM_KP_KP(LEFT_META, W)
    &kp E
    &LHRM_MO_KP(NUM, R)
    &kp T

    &kp Y
    &RHRM_MO_KP(NUM, U)
    &kp I
    &RHRM_KP_KP(LEFT_META, O)
    &kp P

    &mm_numword_numlock
// ├─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┤
// │ LM5 │ LM4 │ LM3 │ LM2 │ LM1 │ LM0 │ RM0 │ RM1 │ RM2 │ RM3 │ RM4 │ RM5 │
    &ht__macro_cancel__kp 0 ESC

    &LHRM_M4(A)
    &LHRM_M3(S)
    &LHRM_M2(D)
    &LHRM_M1(F)
    &LHRM_M0(G)

    &RHRM_M0(H)
    &RHRM_M1(N)
    &RHRM_M2(K)
    &RHRM_M3(L)
    &RHRM_M4(SINGLE_QUOTE)

    &kp RET
// ├─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┼─────┤
// │ LB5 │ LB4 │ LB3 │ LB2 │ LB1 │ LB0 │ RB0 │ RB1 │ RB2 │ RB3 │ RB4 │ RB5 │
    &kp MACRO_UNDO

    &LHRM_KP_KP(RIGHT_ALT, Z)
    &LHRM_KP_KP(LEFT_META, X)
    &kp C
    &LHRM_MO_KP(NUMKP, V)
    &kp B
    ,
    &kp J
    &RHRM_MO_KP(NUMKP, M)
    &mm_comma_semicolon /* mm_comma_semicolon | mm_comma_singlequote */
    &RHRM_KP_MM(LEFT_META, mm_dot_colon) /* mm_dot_colon | mm_dot_doublequotes */
    &RHRM_KP_MM(RIGHT_ALT, mm_excl_qmark) /* mm_excl_qmark | SEMICOLON/COLON */

    &kp MACRO_REDO
// ├─────┼─────┼─────┼─────┼─────┼─────┴─────┼─────┼─────┼─────┼─────┼─────┤
// │ LF5 │ LF4 │ LF3 │ LF2 │ LF1 │           │ RF1 │ RF2 │ RF3 │ RF4 │ RF5 │
    &kp HOME
    &kp END
    &mm_mul_div
    &mm_add_sub
    &mm_equal_equal
    ,
    &mm_parenthesis
    &mm_brackets
    &mm_braces
    &kp PAGE_UP
    &kp PAGE_DOWN
    ,
// ├─────┼─────┼─────┼─────┴─────╯           ╰─────┴─────┼─────┼─────┼─────┤
// │ LH5 │ LH4 │ LH3 │                                   │ RH3 │ RH4 │ RH5 │
    &LHRM_MO_KP(NAV, BACKSPACE)
    &RHRM_KP_KP(LEFT_CONTROL, DELETE)
    XXX

    XXX
    &mm_underscore_minus
    &RHRM_MO_KP(FUN, SPACE)
    ,
// ├─────┼─────┼─────┤                                   ├─────┼─────┼─────┤
// │ LH2 │ LH1 │ LH0 │                                   │ RH0 │ RH1 │ RH2 │
    &RHRM_MO_KP(FUN, TAB)
    &kp LEFT_SHIFT
    XXX

    XXX
    &kp RIGHT_SHIFT
    &mm_slash_backslash
// ╰─────┴─────┴─────╯                                   ╰─────┴─────┴─────╯
)

////////////////////////////////////////////////////////////////

#define ____KEYMAP_NAV

////////////////////////////////

#define NAV_LEFT  mt_home_key 0   LEFT    // tap: left  | long-tap: beginning of line
#define NAV_RIGHT mt_end_key 0    RIGHT   // tap: right | long-tap: end       of line
#define NAV_UP    mt APPLY_MODS(MOD_LCTL, HOME) UP      // tap: up    | long-tap: beginning of document
#define NAV_DOWN  mt APPLY_MODS(MOD_LCTL, END)  DOWN    // tap: down  | long-tap: end       of document

#define NAV_BSPC  mt APPLY_MODS(MOD_LCTL, BSPC) BSPC    // tap: bspc  | long-tap: delete word backward
#define NAV_DEL   mt APPLY_MODS(MOD_LCTL, DEL)  DEL     // tap: del   | long-tap: delete word forward

// long-tap action on hold, short-tap action on all interrupts
ZMK_HOLD_TAP(mt_home_key, bindings = <&mm_home_home__nav>, <&kp>; MT_SETTINGS_DEFAULT)
ZMK_HOLD_TAP(mt_end_key, bindings = <&mm_end_end__nav>, <&kp>; MT_SETTINGS_DEFAULT)

// mask CTRL when holding left/right to avoid accidental jumps to beginning/end of document
#define ZMK_MOD_MORPH__MASK_MODS(NAME, MODS, BINDING) \
    ZMK_MOD_MORPH(NAME, \
        bindings = <BINDING>, <BINDING>; \
        mods = <MODS>; \
    )
ZMK_MOD_MORPH__MASK_MODS(mm_home_home__nav, (MOD_LCTL), &kp HOME)
ZMK_MOD_MORPH__MASK_MODS(mm_end_end__nav,  (MOD_LCTL), &kp END)

////////////////////////////////

