////////////////////////////////////////////////////////////////
/* mod-morph's */

#define ___MOD_MORPHS

// tap: backspace | lshft + tap: delete | rshft + tap: shift-delete
ZMK_MOD_MORPH(morph_bspc_del,
    bindings = <&kp BSPC>, <&kp DEL>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
    keep-mods = <MOD_RSFT>;
)

// reuse basic mod-morph scheme
#define SIMPLE_MORPH(NAME, MOD, BINDING1, BINDING2) \
    ZMK_MOD_MORPH(NAME, \
        mods = <(MOD_L ## MOD|MOD_R ## MOD)>; \
        bindings = <BINDING1>, <BINDING2>; \
    )

SIMPLE_MORPH(morph_comma, SFT, &kp COMMA, &kp SEMICOLON)
SIMPLE_MORPH(morph_dot, SFT, &kp DOT, &kp COLON)
SIMPLE_MORPH(morph_excl, SFT, &kp EXCLAMATION, &kp QMARK)

SIMPLE_MORPH(morph_pars, SFT, &kp LEFT_PARENTHESIS, &kp RIGHT_PARENTHESIS)
SIMPLE_MORPH(morph_bkts, SFT, &kp LEFT_BRACKET, &kp RIGHT_BRACKET)
SIMPLE_MORPH(morph_brcs, SFT, &kp LEFT_BRACE, &kp RIGHT_BRACE)

SIMPLE_MORPH(morph_grave_at, SFT, &kp GRAVE, &kp AT)
SIMPLE_MORPH(morph_dollar_percent, SFT, &kp DOLLAR, &kp PERCENT)

SIMPLE_MORPH(morph_equal_tile, SFT, &kp EQUAL, &kp TILDE)
SIMPLE_MORPH(morph_add_sub, SFT, &kp PLUS, &kp MINUS)
SIMPLE_MORPH(morph_mul_div, SFT, &kp ASTERISK, &kp SLASH)

SIMPLE_MORPH(morph_lt_gt, SFT, &kp LT, &kp GT)
SIMPLE_MORPH(morph_and_or, SFT, &kp AMPERSAND, &kp PIPE)
SIMPLE_MORPH(morph_us_caret, SFT, &kp UNDERSCORE, &kp CARET)

SIMPLE_MORPH(morph_slash_backslash, SFT, &kp SLASH, &kp BACKSLASH)
SIMPLE_MORPH(morph_underscore_minus, SFT, &kp UNDERSCORE, &kp MINUS)

////////////////////////////////////////////////////////////////
/* Homerow mods */

#define ___HOMEROW_MODS

#define KEYS_L  \
        LT0 LT1 LT2 LT3 LT4 \
        LM0 LM1 LM2 LM3 LM4 \
        LB0 LB1 LB2 LB3 LB4
#define KEYS_R \
        RT0 RT1 RT2 RT3 RT4 \
        RM0 RM1 RM2 RM3 RM4 \
        RB0 RB1 RB2 RB3 RB4
#define THUMBS \
        LH2 LH1 LH0 \
        RH0 RH1 RH2

#define MAKE_HRM(NAME, HOLD, TAP, TRIGGER_POS) \
    ZMK_HOLD_TAP(NAME, \
        flavor = "balanced"; \
        tapping-term-ms = <280>; \
        quick-tap-ms = <QUICK_TAP_MS>; \
        require-prior-idle-ms = <150>; \
        bindings = <HOLD>, <TAP>; \
        hold-trigger-key-positions = <TRIGGER_POS>; \
        hold-trigger-on-release; \
    )

MAKE_HRM(hrml, &kp, &kp, KEYS_R THUMBS)  // left-hand HRMs
MAKE_HRM(hrmr, &kp, &kp, KEYS_L THUMBS)  // right-hand HRMs

#define HRML_KP_KP(key_on_hold, key_on_tap) hrml key_on_hold key_on_tap
#define HRMR_KP_KP(key_on_hold, key_on_tap) hrmr key_on_hold key_on_tap

MAKE_HRM(hrml_mo_kp, &mo, &kp, KEYS_R THUMBS)
MAKE_HRM(hrmr_mo_kp, &mo, &kp, KEYS_L THUMBS)

#define HRML_MO_KP(layer_on_hold, key_on_tab) hrml_mo_kp layer_on_hold key_on_tab
#define HRMR_MO_KP(layer_on_hold, key_on_tab) hrmr_mo_kp layer_on_hold key_on_tab

MAKE_HRM(hrml_kp_morph_add_sub, &kp, &morph_add_sub, KEYS_R THUMBS)
MAKE_HRM(hrml_kp_morph_mul_div, &kp, &morph_mul_div, KEYS_R THUMBS)

MAKE_HRM(hrmr_kp_morph_pars, &kp, &morph_pars, KEYS_L THUMBS)
MAKE_HRM(hrmr_kp_morph_bkts, &kp, &morph_bkts, KEYS_L THUMBS)
MAKE_HRM(hrmr_kp_morph_brcs, &kp, &morph_brcs, KEYS_L THUMBS)

#define MAKE_HRML_KP_MORPH(morph_on_tap) \
    MAKE_HRM(hrml_kp_morph_ ## morph_on_tab, &kp, &morph_on_tap, KEYS_R THUMBS)

#define HRML_KP_MORPH(key_on_hold, morph_on_tap) \
    hrml_kp_morph_ ## morph_on_tab key_on_hold 0

////////////////////////////////

#define KEY_HRM_M4    LALT
#define KEY_HRM_M3    SYM
#define KEY_HRM_M2    LSHFT
#define KEY_HRM_M1    LCTRL
#define KEY_HRM_M0    0

#define MOD_HRM_M4    LA
#define MOD_HRM_M3    0
#define MOD_HRM_M2    LS
#define MOD_HRM_M1    LC
#define MOD_HRM_M0    0

#define HRML_M4_HOLD_TAP(key_on_tap) HRML_KP_KP(KEY_HRM_M4, key_on_tap)
#define HRML_M3_HOLD_TAP(key_on_tap) HRML_MO_KP(KEY_HRM_M3, key_on_tap)
#define HRML_M2_HOLD_TAP(key_on_tap) HRML_KP_KP(KEY_HRM_M2, key_on_tap)
#define HRML_M1_HOLD_TAP(key_on_tap) HRML_KP_KP(KEY_HRM_M1, key_on_tap)
#define HRML_M0_HOLD_TAP(key_on_tap) kp key_on_tap

#define HRMR_M0_HOLD_TAP(key_on_tap) kp key_on_tap
#define HRMR_M1_HOLD_TAP(key_on_tap) HRMR_KP_KP(KEY_HRM_M1, key_on_tap)
#define HRMR_M2_HOLD_TAP(key_on_tap) HRMR_KP_KP(KEY_HRM_M2, key_on_tap)
#define HRMR_M3_HOLD_TAP(key_on_tap) HRMR_MO_KP(KEY_HRM_M3, key_on_tap)
#define HRMR_M4_HOLD_TAP(key_on_tap) HRMR_KP_KP(KEY_HRM_M4, key_on_tap)

#define HRML_M4_TAP() kp KEY_HRM_M4
#define HRML_M3_TAP() mo KEY_HRM_M3
#define HRML_M2_TAP() kp KEY_HRM_M2
#define HRML_M1_TAP() kp KEY_HRM_M1
#define HRML_M0_TAP() none

#define HRMR_M0_TAP() none
#define HRMR_M1_TAP() kp KEY_HRM_M1
#define HRMR_M2_TAP() kp KEY_HRM_M2
#define HRMR_M3_TAP() mo KEY_HRM_M3
#define HRMR_M4_TAP() kp KEY_HRM_M4

#define HRML_M2_HOLD_MORPH(morph_on_tap) HRML_KP_MORPH(KEY_HRM_M2, morph_on_tap)

////////////////////////////////

#define HRML_B4(key) kp key
#define HRML_B3(key) HRML_KP_KP(LGUI, key)
#define HRML_B2(key) kp key
#define HRML_B1(key) kp key
#define HRML_B0(key) HRML_MO_KP(NUM, key)

#define HRMR_B4(key) kp key
#define HRMR_B3(key) HRMR_KP_KP(LGUI, key)
#define HRMR_B2(key) kp key
#define HRMR_B1(key) kp key
#define HRMR_B0(key) HRMR_MO_KP(NUM, key)

